# AI Deep Coder Configuration
# Copy this file to .env and fill in your API keys.

# At least one of these is required:
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional: override the default model
# Format: provider:model (e.g., "anthropic:claude-sonnet-4-20250514", "openai:gpt-4o")
# AI_DEEP_CODER_MODEL=anthropic:claude-sonnet-4-20250514

# Optional: override the working directory for file operations
# AI_DEEP_CODER_WORKSPACE=/path/to/your/project
